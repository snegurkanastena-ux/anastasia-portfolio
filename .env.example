# Переменные для POST /api/contact (письмо на neuroera@yandex.com из src/lib/site.ts).
# Локально: скопируйте .env.local.template → .env.local и задайте SMTP_PASS, затем перезапустите dev.

# === Обязательно (пустые строки и пробелы трактуются как «не задано» → 503) ===
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=neuroera@yandex.com
SMTP_PASS=

# === Режим шифрования (как в nodemailer: secure + requireTLS для 587) ===
# 1 или true — SSL (типично с портом 465). Для 587 обычно: SMTP_SECURE=0
SMTP_SECURE=1

# === Необязательно ===
# CONTACT_MAIL_FROM=neuroera@yandex.com
# CONTACT_MAIL_FROM_NAME=Portfolio

# Пример STARTTLS: SMTP_PORT=587 и SMTP_SECURE=0
# Пароль приложения Яндекс: https://yandex.ru/support/id/authorization/app-passwords.html
