# Скопируйте этот файл в .env.local (в корень проекта) и задайте SMTP_PASS.
# После создания или правки .env.local перезапустите dev-сервер (npm run dev).
# Полный список переменных и комментарии: см. .env.example

# --- Обязательно для POST /api/contact (без этого — 503 и текст failedConfig в модалке) ---
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=1
SMTP_USER=neuroera@yandex.com
SMTP_PASS=

# --- Необязательно (From в письме; по умолчанию = SMTP_USER и имя «Portfolio») ---
# CONTACT_MAIL_FROM=neuroera@yandex.com
# CONTACT_MAIL_FROM_NAME=Portfolio

# Альтернатива Яндексу (STARTTLS): SMTP_PORT=587, SMTP_SECURE=0
# Пароль приложения: https://yandex.ru/support/id/authorization/app-passwords.html
